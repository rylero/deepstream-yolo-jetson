NT_TEAM_NUMBER=6238
NUM_CAMERAS=2
# Capture device nodes — run  v4l2-ctl --list-devices  on the Jetson to confirm.
# USB cameras expose 2 /dev/videoX nodes each; only the first is a capture device.
CAMERA_DEVICES=/dev/video0,/dev/video2
# Uncomment to test with a file instead of cameras:
#VIDEO_URI=file:///opt/nvidia/deepstream/deepstream/samples/streams/sample_1080p_h264.mp4
